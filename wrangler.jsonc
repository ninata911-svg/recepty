{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "recepty",
  "main": "src/index.js",
  "compatibility_date": "2026-07-13",

  "observability": {
    "enabled": true
  },

  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ]
  },

  "compatibility_flags": [
    "nodejs_compat"
  ],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "recepty-db",
      "database_id": "ВАШ_НАСТОЯЩИЙ_DATABASE_ID"
    }
  ]
}
