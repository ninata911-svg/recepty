{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "recepty-importer",
  "main": "src/importer.js",
  "compatibility_date": "2026-07-17",

  "observability": {
    "enabled": true
  },

  "compatibility_flags": [
    "nodejs_compat"
  ],

  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "recepty-images"
    }
  ]
}
